generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ONG
  PESSOA_FISICA
}

enum AdoptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  email            String            @unique
  passwordHash     String
  name             String
  cep              String
  state            String?
  city             String?
  contact          String?
  address          String?
  cpf              String?           @unique
  cnpj             String?           @unique
  role             Role
  createdAt        DateTime          @default(now())
  pets             Pet[]             @relation("OngPets")
  adoptionRequests AdoptionRequest[] @relation("AdopterRequests")
}

model Pet {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  species          String
  age              Int
  description      String
  donationReason   String?
  isCastrated      Boolean  @default(false)
  sex              String   @default("Indefinido")
  size             String   @default("Indefinido")
  isDewormed        Boolean  @default(false)
  hasVaccineV8      Boolean  @default(false)
  hasVaccineGiardia Boolean  @default(false)
  hasVaccineFlu     Boolean  @default(false)
  hasVaccineRabies  Boolean  @default(false)
  hasVaccineFeline  Boolean  @default(false)
  hasVaccineFelv    Boolean  @default(false)
  hasHistoryOfIllness        Boolean  @default(false)
  illnessDescription         String?
  hasOtherHealthInfo         Boolean  @default(false)
  otherHealthInfoDescription String?
  photoUrl         String            @default("")
  photoUrls        String[]          @default([])
  featuredPhotoIndex Int             @default(0)
  isAdopted        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  ongId            String            @db.Uuid // trocar no futuro para owner e ownerId no BACK TODO
  ong              User              @relation("OngPets", fields: [ongId], references: [id], onDelete: Restrict)
  adoptionRequests AdoptionRequest[] @relation("PetRequests")
}

model AdoptionRequest {
  id         String         @id @default(uuid()) @db.Uuid
  petId      String         @db.Uuid
  adopterId  String         @db.Uuid
  status     AdoptionStatus @default(PENDING)
  message    String
  createdAt  DateTime       @default(now())

  pet        Pet            @relation("PetRequests", fields: [petId], references: [id], onDelete: Cascade)
  adopter    User           @relation("AdopterRequests", fields: [adopterId], references: [id], onDelete: Cascade)

  @@unique([petId, adopterId])
}
